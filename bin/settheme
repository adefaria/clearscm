#!/bin/bash
DARK_ENGINE="MyDarkTheme"
LIGHT_ENGINE="MyLightTheme"
LAT="33.12"
LON="-117.29"
HELIOCRON="/usr/local/bin/heliocron"
COLOR_CHOOSER="$HOME/.gtkrc-2.0-gnome-color-chooser"
HOSTNAME=$(hostname)

set_mode() {
    local mode=$1
    local engine
    local pref

    if [ "$mode" == "dark" ]; then
        engine="$DARK_ENGINE"
        pref="prefer-dark"
        # Restore AntiGravity's blue tint if a backup exists
        if [ -f "${COLOR_CHOOSER}.bak" ]; then
            mv "${COLOR_CHOOSER}.bak" "$COLOR_CHOOSER"
        fi
    else
        engine="$LIGHT_ENGINE"
        pref="prefer-light"
        # Hide AntiGravity's blue tint so Light Mode isn't "stained"
        if [ -f "$COLOR_CHOOSER" ]; then
            mv "$COLOR_CHOOSER" "${COLOR_CHOOSER}.bak"
        fi
        # Signal to Brave/GTK3 apps to use Light variants
        sed -i 's/gtk-application-prefer-dark-theme=1/gtk-application-prefer-dark-theme=0/g' ~/.config/gtk-3.0/settings.ini

        # CLEAR CACHE: This is the missing link for AntiGravity
        # It forces MATE to stop "remembering" the blue color-scheme
        gsettings set org.mate.interface gtk-color-scheme ''

        # Force GTK2 (AntiGravity) to realize the blue config is gone
        export GTK2_RC_FILES="$HOME/.gtkrc-2.0"
        gsettings reset org.mate.interface gtk-color-scheme
    fi

    echo "Switching to $mode ($engine)..."

    # 1. Update GSettings (MATE & GNOME)
    gsettings set org.mate.interface gtk-theme "$engine"
    gsettings set org.gnome.desktop.interface gtk-theme "$engine"
    gsettings set org.gnome.desktop.interface color-scheme "$pref"

    # 2. Update Panel CSS dynamically by Hostname and Solar Mode
    if [ "$HOSTNAME" == "Mars" ]; then
        if [ "$mode" == "dark" ]; then
            cat <<'EOF' > ~/.config/gtk-3.0/gtk.css
.mate-panel-menu-bar,
.mate-panel-menu-bar label,
.mate-panel-applet label,
MatePanelApplet label,
#mate-panel-menu-bar label {
    color: #f8f8f2;
    text-shadow: none;
}
EOF
        else
            cat <<'EOF' > ~/.config/gtk-3.0/gtk.css
.mate-panel-menu-bar,
.mate-panel-menu-bar label,
.mate-panel-applet label,
MatePanelApplet label,
#mate-panel-menu-bar label {
    color: #2e3440;
    text-shadow: none;
}
EOF
        fi
    else
        # Earth (Desktop) Rule
        if [ "$mode" == "dark" ]; then
            cat <<'EOF' > ~/.config/gtk-3.0/gtk.css
.mate-panel-menu-bar,
.mate-panel-menu-bar label,
.mate-panel-applet label,
MatePanelApplet label,
#mate-panel-menu-bar label {
    color: #ffffff;
    text-shadow: 1px 1px 0 #000000;
}
EOF
        else
            cat <<'EOF' > ~/.config/gtk-3.0/gtk.css
.mate-panel-menu-bar,
.mate-panel-menu-bar label,
.mate-panel-applet label,
MatePanelApplet label,
#mate-panel-menu-bar label {
    color: #2e3440;
    text-shadow: none;
}
EOF
        fi
    fi

    # 3. Broadcast the change
    dbus-send --session --dest=org.mate.SettingsDaemon \
        --type=method_call /org/mate/SettingsDaemon/Plugins/XSettings \
        org.mate.SettingsDaemon.Plugins.XSettings.SetString \
        string:"Net/ThemeName" string:"$engine"

    # 4. Brave/Chromium "Nudge"
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-light'
    sleep 0.1
    gsettings set org.gnome.desktop.interface color-scheme "$pref"
    
    # 5. Emerald Reload (Graceful, no-flash)
    if pgrep -x "emerald" > /dev/null; then
        dbus-send --type=method_call --dest=org.beryl_project.emerald \
            /org/beryl_project/emerald org.beryl_project.emerald.reload_settings
    fi

    # 6. Apply to MATE panel cleanly by backgrounding the entire new session
    setsid mate-panel --replace >/dev/null 2>&1 &
}

case "$1" in
    -n|--night) set_mode "dark"  ;;
    -d|--day)   set_mode "light" ;;
    -t|--toggle)
        CURRENT=$(gsettings get org.mate.interface gtk-theme | tr -d "'" | xargs)
        if [ "$CURRENT" == "$DARK_ENGINE" ]; then
            set_mode "light"
        else
            set_mode "dark"
        fi
        ;;
    "")
        if $HELIOCRON --latitude $LAT --longitude $LON poll | grep -q "Day"; then
            set_mode "light"
        else
            set_mode "dark"
        fi
        ;;
    *)
        echo "Usage: $(basename "$0") [-t|--toggle] [-d|--day] [-n|--night]"
        exit 1
        ;;
esac
