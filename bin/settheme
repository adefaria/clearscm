#!/bin/bash
# /opt/clearscm/bin/settheme

# The Engines that actually work (Verified by the Guru)
DARK_ENGINE="Yaru-blue-dark"
LIGHT_ENGINE="Yaru"

# Configuration
LAT=33.14
LON=-117.16
HELIOCRON=/usr/local/bin/heliocron

set_mode() {
    local mode=$1
    local engine
    local pref

    [ "$mode" == "dark" ] && engine="Yaru-blue-dark" || engine="Yaru"
    [ "$mode" == "dark" ] && pref="prefer-dark" || pref="prefer-light"

    echo "Switching to $mode ($engine)..."

    # 1. Update the GSettings (The "Source of Truth")
    gsettings set org.mate.interface gtk-theme "$engine"
    gsettings set org.gnome.desktop.interface gtk-theme "$engine"
    gsettings set org.gnome.desktop.interface color-scheme "$pref"

    # 2. THE NO-FLICKER PULSE:
    # This tells the XSettings plugin to broadcast the new theme
    # to all running windows (including Caja) WITHOUT restarting them.
    dbus-send --session --dest=org.mate.SettingsDaemon \
        --type=method_call /org/mate/SettingsDaemon/Plugins/XSettings \
        org.mate.SettingsDaemon.Plugins.XSettings.SetString \
        string:"Net/ThemeName" string:"$engine"
}

case "$1" in
    -n|--night) set_mode "dark"  ;;
    -d|--day)   set_mode "light" ;;
    -t|--toggle)
        CURRENT=$(gsettings get org.mate.interface gtk-theme | tr -d "'")
        [ "$CURRENT" == "$DARK_ENGINE" ] && set_mode "light" || set_mode "dark"
        ;;
    "")
        if $HELIOCRON --latitude $LAT --longitude $LON poll | grep -q "Day"; then
            set_mode "light"
        else
            set_mode "dark"
        fi
        ;;
    *)
        echo "Usage: $(basename "$0") [-t|--toggle] [-d|--day] [-n|--night]"
        exit 1
        ;;
esac
