#!/bin/bash

#-------------------------------------------------------------------------------
# SCRIPT: mp4fix.sh (CRF Version)
# DESCRIPTION: Re-encodes video to H.264 for web compatibility. 
#              Uses CRF for consistent visual quality.
#-------------------------------------------------------------------------------

# --- Configuration ---
# CRF (Constant Rate Factor): 18 is near-lossless, 23 is default, 28 is low quality.
# Lower = Higher Quality / Larger File. 20-22 is great for high-quality web.
QUALITY_CRF="22"

# Set the encoding preset. 'medium' is usually better for CRF quality.
PRESET_VALUE="medium"

# --- Encoder Configuration ---
NVENC_ENCODER="h264_nvenc"
SOFTWARE_ENCODER="libx264"
ENCODER_USED=""

# --- Argument Validation ---
if [ -z "$1" ]; then
    echo "Error: Missing input file argument."
    echo "Usage: $0 <path/to/file.mp4 or .mov>"
    exit 1
fi

INPUT_FILE="$1"
if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: File not found at '$INPUT_FILE'."
    exit 1
fi

if [[ "$INPUT_FILE" =~ \.mov$ ]] || [[ "$INPUT_FILE" =~ \.MOV$ ]]; then
    FINAL_OUTPUT_FILE="${INPUT_FILE%.*}.mp4"
else
    FINAL_OUTPUT_FILE="$INPUT_FILE"
fi

FILENAME=$(basename "$1")
TEMP_FILE="/tmp/${FILENAME%.*}.temp.mp4"
ERROR_LOG="ffmpeg_error.log"

# --- Encoding Function ---
run_ffmpeg() {
    local encoder=$1
    echo "----------------------------------------------------------------------"
    echo "FFmpeg Command Details:"
    echo "Video Codec: $encoder"
    echo "Quality Control: CRF $QUALITY_CRF (Constant Quality)"
    echo "Color Space: yuv420p (Crucial for browser playback)"
    echo "Optimization: +faststart (Web streaming ready)"
    echo "----------------------------------------------------------------------"
    
    # Logic change: Replaced -b:v with -crf
    # Note: NVENC uses -cq or -rc vbr, so we adapt for both hardware and software
    if [ "$encoder" == "$NVENC_ENCODER" ]; then
        ffmpeg -i "$INPUT_FILE" -y -c:v "$encoder" -preset p4 -rc vbr -cq "$QUALITY_CRF" -pix_fmt yuv420p -c:a copy -movflags +faststart "$TEMP_FILE" 2> "$ERROR_LOG"
    else
        ffmpeg -i "$INPUT_FILE" -y -c:v "$encoder" -preset "$PRESET_VALUE" -crf "$QUALITY_CRF" -pix_fmt yuv420p -c:a copy -movflags +faststart "$TEMP_FILE" 2> "$ERROR_LOG"
    fi
    return $?
}

# --- Execution ---
echo "Starting re-encoding of: $INPUT_FILE"
run_ffmpeg "$NVENC_ENCODER"
ENCODE_STATUS=$?
ENCODER_USED="$NVENC_ENCODER"

if [ $ENCODE_STATUS -ne 0 ]; then
    if grep -qE "Cannot load libcuda|Unknown encoder|Error initializing" "$ERROR_LOG"; then
        echo "Hardware encoder failed. Falling back to software ($SOFTWARE_ENCODER)..."
        run_ffmpeg "$SOFTWARE_ENCODER"
        ENCODE_STATUS=$?
        ENCODER_USED="$SOFTWARE_ENCODER"
    fi
fi

rm -f "$ERROR_LOG"

# --- Finalizing ---
if [ $ENCODE_STATUS -eq 0 ]; then
    mv -f "$TEMP_FILE" "$FINAL_OUTPUT_FILE"
    echo "✅ Success: Optimized for web using $ENCODER_USED at CRF $QUALITY_CRF."
else
    echo "❌ Critical Error: Encoding failed."
    [ -f "$TEMP_FILE" ] && rm -f "$TEMP_FILE"
    exit 1
fi

exit 0
