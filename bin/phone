#!/bin/bash
export PATH="/opt/android-sdk/cmdline-tools/latest/bin:$PATH"

ADB_SERVER_PORT=5038
ADB_CONNECT_PORT=6666
MAX_SIZE=1300
PHONE_IP="${1:-192.168.86.76}"

# Store original timeout to restore later (default is usually 60000)
ORIGINAL_TIMEOUT=$(adb -s "$PHONE_IP:$ADB_CONNECT_PORT" shell settings get system screen_off_timeout 2>/dev/null)

cleanup() {
  echo "Restoring timeout and disconnecting..."
  # Restore the original timeout setting
  if [ ! -z "$ORIGINAL_TIMEOUT" ]; then
    adb -s "$PHONE_IP:$ADB_CONNECT_PORT" shell settings put system screen_off_timeout "$ORIGINAL_TIMEOUT"
  fi
  adb disconnect "$PHONE_IP:$ADB_CONNECT_PORT"
  # adb kill-server # Generally not recommended if other tools use adb, but keeping if you prefer it
  exit 0
}

# Added EXIT to the trap so it runs when scrcpy closes
trap 'cleanup' 1 2 15 EXIT

if pgrep -x "scrcpy" > /dev/null; then
  xdotool search --class "scrcpy" windowactivate
  exit 0
fi

adb start-server
adb connect "$PHONE_IP:$ADB_CONNECT_PORT" > /dev/null

if [ $? -eq 0 ]; then
    # Force screen timeout to 24 hours (86400000 ms) to bypass wireless charging sleep
    adb -s "$PHONE_IP:$ADB_CONNECT_PORT" shell settings put system screen_off_timeout 86400000

    # 3. Launch scrcpy (Removed & from end so script stays alive for the trap)
    # Added --window-title so wmctrl has a reliable string to find
    scrcpy -m $MAX_SIZE --stay-awake --turn-screen-off --power-off-on-close --window-title "scrcpy-phone" > /dev/null 2>&1 &
    
    # Retry loop: move window
    count=0
    while [ $count -lt 10 ]; do
        # Using the specific window title we set above
        wmctrl -r "scrcpy-phone" -e 0,3840,350,-1,-1
        if [ $? -eq 0 ]; then
            break
        fi
        sleep 1
        ((count++))
    done

    # Wait for the background scrcpy process to finish so the trap can trigger on close
    wait $(pgrep -f "scrcpy-phone")
else
    echo "Adb connection failed. Please check the IP address."
fi
