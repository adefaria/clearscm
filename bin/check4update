#!/bin/bash
timeout=5
expireTime=1200
systems="\
  earth\
  mars\
  defaria.com\
"

function notify {
  echo $1
}

function yesno {
  question=$1
  say $question

  # 1. Detect if the current theme prefers dark
  # (Works for modern GNOME, MATE, and desktop environments respecting color-scheme)
  CURRENT_SCHEME=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null | tr -d "'")

  # 2. Determine the opposite theme
  if [ "$CURRENT_SCHEME" = "prefer-dark" ]; then
    # System is DARK -> Force LIGHT dialog
    # (Leaving it empty usually defaults to light, or you can specify a light theme like 'Adwaita')
    OPPOSITE_THEME=":light"
  else
    # System is LIGHT -> Force DARK dialog
    OPPOSITE_THEME=":dark"
  fi

  # 3. Launch Zenity with the inverted theme
  GTK_THEME="$OPPOSITE_THEME" zenity --question --text "$question" --width=300 2> /dev/null
}
    
update=$1;

yesno "Start update"

for system in $systems; do
  notify "Checking $system for updates"
  if ! ping -c 1 -W 2 $system &> /dev/null; then
    echo "$system down - skipping"
  else 
    ssh $system sudo flatpak update -y --noninteractive | grep -ve Info -e 'no longer' -e ^$ -e tv.plex -e 'Nothing to do'
    ssh $system sudo apt-get -qq update
    ssh $system apt list --upgradeable 2> /dev/null | grep -v "^Listing" > /tmp/check4update.list

    if [ $(wc -l /tmp/check4update.list 2> /dev/null | cut -f1 -d' ') -ne 0 ]; then
      cat /tmp/check4update.list

      if yesno "There are updates for $system\nApply them now?"; then
        ssh $system sudo /opt/clearscm/bin/update-system
      else
        notify "$system not updated"
      fi
    else
      notify "$system is up to date"
    fi

    rm -f /tmp/check4update.list

    reboot=$(ssh $system " if [ -e /var/run/reboot-required ]; then echo 1; else echo 0; fi")
    if [ "$reboot" = 1 ]; then
      if yesno "$system needs to be rebooted\nReboot now?"; then
        ssh $system sudo reboot
      else
        notify "$system not rebooted"
      fi
  fi
fi
done
